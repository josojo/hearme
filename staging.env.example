# Copy to /home/ubuntu/hearme/.env on the staging host. Do not commit the real
# file. Use URL-safe random values to avoid DSN escaping surprises, for example:
#   openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 40; echo

HEARME_STAGING_POSTGRES_ADMIN_PASSWORD=replace_with_random_value
HEARME_STAGING_POSTGRES_WEB_PASSWORD=replace_with_random_value
HEARME_STAGING_POSTGRES_BROKER_PASSWORD=replace_with_random_value

# Base64 of exactly 32 random bytes:
#   openssl rand -base64 32
HEARME_STAGING_BROKER_SIGNING_KEY=replace_with_base64_32_byte_seed

# Public HTTPS callback routed by Caddy to self-bridge.
HEARME_STAGING_SELF_ENDPOINT=https://3-121-186-133.sslip.io/self/callback
