# Local dev — points at the postgres started by docker-compose at the repo root.
DATABASE_URL=postgres://hearme_web:hearme_web_dev@localhost:5432/hearme

# Public origin of the deployment. Used for canonical/Open Graph URLs so shared
# question links unfurl with the right absolute image + URL. Falls back to
# http://localhost:3000 when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Internal base URL of the broker, fetched server-side by /stats for the
# privacy-safe agent + respondent counts the web role can't read directly.
# Falls back to http://localhost:8000 when unset (docker-compose: http://broker:8000).
BROKER_URL=http://localhost:8000

# Social links shown in the footer. Defaults are placeholders — set these to
# the real channels (or leave unset to use the placeholder hrefs).
NEXT_PUBLIC_SOCIAL_X=https://x.com/hearme
NEXT_PUBLIC_SOCIAL_TELEGRAM=https://t.me/hearme
NEXT_PUBLIC_SOCIAL_DISCORD=https://discord.gg/hearme
